# Maintainer: Jackson McDonald <jacksonrmcdonald@gmail.com>
pkgname=pushmute
pkgver=0.1.0
pkgrel=1
pkgdesc="Push-to-mute for PipeWire — route your mic to one app and silence it with a global hotkey"
arch=('x86_64')
url="https://github.com/JacksonMcDonaldDev/pushmute"
license=('MIT' 'Apache-2.0')
depends=('pipewire' 'wireplumber')
makedepends=('cargo')
install="$pkgname.install"
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
# Source tarball is generated by GitHub at tag time; the release/CD automation
# refreshes this checksum (and regenerates .SRCINFO) when the tag is cut.
sha256sums=('SKIP')

prepare() {
	cd "$pkgname-$pkgver"
	export RUSTUP_TOOLCHAIN=stable
	cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
	cd "$pkgname-$pkgver"
	export RUSTUP_TOOLCHAIN=stable
	export CARGO_TARGET_DIR=target
	cargo build --frozen --release
}

check() {
	cd "$pkgname-$pkgver"
	export RUSTUP_TOOLCHAIN=stable
	cargo test --frozen --release
}

package() {
	cd "$pkgname-$pkgver"

	install -Dm755 "target/release/pushmute" "$pkgdir/usr/bin/pushmute"

	# Ship one canonical unit (ExecStart=%h/.local/bin/pushmute run for install.sh);
	# the system package runs the binary from /usr/bin, so rewrite that one line.
	install -Dm644 pushmute.service "$pkgdir/usr/lib/systemd/user/pushmute.service"
	sed -i 's|%h/.local/bin/pushmute|/usr/bin/pushmute|' \
		"$pkgdir/usr/lib/systemd/user/pushmute.service"

	install -Dm644 packaging/pushmute.desktop \
		"$pkgdir/usr/share/applications/pushmute.desktop"
	install -Dm644 assets/pushmute.svg \
		"$pkgdir/usr/share/icons/hicolor/scalable/apps/pushmute.svg"

	install -Dm644 LICENSE-MIT "$pkgdir/usr/share/licenses/$pkgname/LICENSE-MIT"
	install -Dm644 LICENSE-APACHE "$pkgdir/usr/share/licenses/$pkgname/LICENSE-APACHE"
}
